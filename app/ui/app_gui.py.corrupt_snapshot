    def _find_korean_name_from_explorer(self, raw_symbol: str) -> str:
        """Explorer ??좎럩????좎럩?????좎럩?좈뇡遺용퓠????좎럩???ル굝????좎룞??夷??좎럩?녶뜝????좎룞???"""
