                def _sma(values, period):
                    out = []
                    for i in range(len(values)):
                        if i + 1 < period:
                            out.append(float("nan"))
                        else:
                            window = values[i - period + 1 : i + 1]
                            out.append(sum(window) / period)
                    return out

