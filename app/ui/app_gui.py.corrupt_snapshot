                left, market = [x.strip() for x in raw.split("/", 1)]
            tokens = [x for x in str(left or "").split() if x]
            symbol = tokens[0] if tokens else "--"
            name = " ".join(tokens[1:]).strip() if len(tokens) > 1 else "--"
