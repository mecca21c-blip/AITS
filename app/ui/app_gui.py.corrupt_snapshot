            p.setPen(Qt.PenStyle.NoPen)
            p.setBrush(QBrush(QColor(self._bg)))
            p.drawEllipse(rect)
            p.setPen(QPen(QColor(self._fg)))
            f = self.font()
            f.setBold(True)
            f.setPixelSize(11)
            p.setFont(f)
            p.drawText(rect, int(Qt.AlignmentFlag.AlignCenter), self._letter)
        except Exception:
            try:
                super().paintEvent(event)
            except Exception:
                pass


