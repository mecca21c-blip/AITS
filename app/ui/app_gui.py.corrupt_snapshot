    def _fmt_change_pct(self, rate: float) -> str:
        try:
            x = float(rate or 0.0)
            if -1.0 <= x <= 1.0:
                return f"{x * 100.0:.2f}%"
            return f"{x:.2f}%"
        except Exception:
