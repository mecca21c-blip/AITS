                    y_lo = min(y_lo, tp)
                    y_hi = max(y_hi, tp)
                if sl > 0:
                    y_lo = min(y_lo, sl)
                    y_hi = max(y_hi, sl)
                ax.set_ylim(y_lo, y_hi)
                n = len(ohlc_rows)
