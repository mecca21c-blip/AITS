        if hasattr(self, '_ensure_inflight') and self._ensure_inflight:
            self._log.info(f"[ORDER-ENSURE] skip re-entry reason={reason}")
            return False
        
        # 1????좎럥沅???좎??뉐뜝?獄쎻뫜??
