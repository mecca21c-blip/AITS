    def _format_seconds_to_hhmmss(self, seconds: int) -> str:
        try:
            s = int(seconds)
        except (TypeError, ValueError):
            s = 0
        if s < 0:
            s = 0
        h = s // 3600
        m = (s % 3600) // 60
        sec = s % 60
        return f"{h:02d}:{m:02d}:{sec:02d}"

