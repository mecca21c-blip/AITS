                ax.tick_params(axis="x", labelsize=9, colors="#6b7280")
                ax.tick_params(axis="y", labelsize=9, colors="#6b7280")
                if n <= 5:
                    ax.set_xticks(list(range(n)))
                else:
                    _ti = sorted(
                        {0, n // 4, n // 2, (3 * n) // 4, n - 1}
                    )
                    ax.set_xticks(_ti)
                if tp > 0:
                    ax.axhline(tp, color="#22c55e", linestyle="--", linewidth=1.1, alpha=0.9)
