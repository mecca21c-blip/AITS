    def _market_score_display_value(self, row_obj) -> int:
        try:
            for key in ("ai_score", "score", "_candidate_score"):
                if isinstance(row_obj, dict):
                    raw = row_obj.get(key)
                else:
                    raw = getattr(row_obj, key, None)
                if raw is None:
                    continue
                val = float(raw)
                if key == "_candidate_score" and val <= 20:
                    val = val * 5.0
                return int(max(0, min(100, round(val))))
        except Exception:
            pass
        return 0

