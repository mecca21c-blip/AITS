def _load_qdarktheme_light_qss() -> tuple[str, str]:
    """qdarktheme 媛?????쇱씠??QSS 諛섑솚, ?ㅽ뙣 ??鍮?臾몄옄??諛섑솚."""
    try:
        import qdarktheme  # type: ignore

        qss = ""
        try:
            qss = qdarktheme.load_stylesheet("light")
        except TypeError:
            qss = qdarktheme.load_stylesheet(theme="light")
        except Exception:
            qss = ""
        if qss:
            return qss, "qdarktheme_light"
        return "", "qdarktheme_empty"
    except Exception:
        return "", "fallback_no_qdarktheme"


def _build_aits_combined_stylesheet() -> tuple[str, str]:
    """
    踰좎씠???뚮쭏 + 湲곗〈 KMTS + AITS override瑜??쒖꽌?濡??⑹꽦?쒕떎.
    - qdarktheme媛 ?놁쑝硫?湲곗〈 KMTS + AITS override留??곸슜
    """
    base_qss, theme_meta = _load_qdarktheme_light_qss()
    aits_override_qss = _build_aits_override_qss()
    parts = [base_qss, KMTS_LIGHT_QSS, aits_override_qss]
    combined = "\n".join([p for p in parts if isinstance(p, str) and p.strip()])
    return combined, theme_meta


def main(root_dir: str, data_dir: str):
    # DB 諛?湲곕낯 ?ㅼ젙 珥덇린??    init_db(os.path.join(root_dir, "data"))
    init_prefs(root_dir, data_dir)
    from app.db.trades_db import init_trades_db
    init_trades_db(data_dir)

    # [PATCH] UI ?ㅼ젙?먯꽌 ?먮룞濡쒓렇???꾩씠??????곹깭 ?쎄린
    try:
        settings = load_settings()
    except Exception:
        settings = AppSettings()

    ui = getattr(settings, "ui", None)
    saved_id = ""
    auto_login = False
    remember_id = False

    # settings.ui ?먯꽌 saved_id / auto_login / remember_id 蹂듭썝
    if ui is not None:
        try:
            # pydantic 紐⑤뜽??寃쎌슦
            if hasattr(ui, "model_dump"):
                ui_dict = ui.model_dump()
            # dict ??寃쎌슦
            elif isinstance(ui, dict):
                ui_dict = dict(ui)
            else:
                ui_dict = {}
        except Exception:
            ui_dict = {}
        saved_id = (ui_dict.get("saved_id") or "").strip()
        auto_login = bool(ui_dict.get("auto_login", False))
        remember_id = bool(ui_dict.get("remember_id", False))

    # Qt ???앹꽦
    app = QApplication.instance() or QApplication(sys.argv)

    # [UI-QSS] 踰좎씠???뚮쭏(light) + AITS override ?⑹꽦 ?곸슜
    try:
        app.setStyle(QStyleFactory.create("Fusion"))
    except Exception:
        pass
    try:
        combined_qss, theme_meta = _build_aits_combined_stylesheet()
        app.setStyleSheet(combined_qss)
        logging.getLogger(__name__).info(
            "[UI-QSS] applied preset=%s theme_source=%s",
            "AITS_COMBINED",
            theme_meta,
        )
    except Exception as e:
        logging.getLogger(__name__).warning(f"[UI-QSS] apply failed err={e}")

    # 蹂몃Ц/?낅젰 湲곕낯 湲?먯깋 寃??(?쒖씤?? ?뚯깋 ?띿뒪??諛⑹?)
    try:
        pal = app.palette()
        pal.setColor(pal.ColorRole.WindowText, QColor(0, 0, 0))
        pal.setColor(pal.ColorRole.Text, QColor(0, 0, 0))
        app.setPalette(pal)
    except Exception:
        pass

    # [PATCH] 怨꾩젙 ?앹꽦 ?앹뾽 ?쒓굅: ??긽 濡쒓렇???ㅼ씠?쇰줈洹몃쭔 ?ъ슜
    state = AppState()

    # ??긽 濡쒓렇??李??쒖떆 (?먮룞 濡쒓렇???쒓굅)
    login_dlg = LoginDialog()
    if login_dlg.exec() != QDialog.Accepted:
        sys.exit(0)
    
    # 濡쒓렇???깃났 泥섎━
    state.login(login_dlg.email.text())

    # 硫붿씤 ?덈룄???앹꽦 諛??쒖떆
    window = MainWindow(state, root_dir, data_dir)
    window.show()
    sys.exit(app.exec())
