    def _sanitize_status_msg(self, msg: str) -> tuple[str | None, str]:
        """
        硫붿떆吏?먯꽌 ?좏뻾 ?꾩씠肄섏쓣 遺꾨━?섏뿬 (icon, text) 諛섑솚
        ?? "?윟 ?뺤긽" ??("?윟", "?뺤긽")
        ?? "??λ맖" ??(None, "??λ맖")
        """
        import re
        
        # ?꾩씠肄??⑦꽩: ?대え吏 + 怨듬갚
        icon_patterns = [
            (r"^??s+", "??),
            (r"^?윟\s+", "?윟"), 
            (r"^?뵶\s+", "?뵶"),
            (r"^??s+", "??),
            (r"^?좑툘\s+", "?좑툘"),
            (r"^?뱄툘\s+", "?뱄툘"),
            (r"^?뮶\s+", "?뮶"),
            (r"^??s+", "??)
        ]
        
        for pattern, icon in icon_patterns:
            if re.match(pattern, msg):
                text = re.sub(pattern, "", msg)
                return icon, text
        
        return None, msg

