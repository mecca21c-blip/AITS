    def _clear_layout_items_detach(self, layout) -> None:
        try:
            if layout is None:
                return
            while layout.count():
                item = layout.takeAt(0)
                if item is None:
                    continue
                w = item.widget()
                if w is not None:
                    try:
                        w.setParent(None)
                    except Exception:
                        pass
                    continue
                child = item.layout()
                if child is not None:
                    self._clear_layout_items_detach(child)
        except Exception:
            pass

