    def _get_ai_managed_current_row(self):
        try:
            row = self.tbl_ai_managed.currentRow()
            if row is not None and int(row) >= 0:
                return int(row)
        except Exception:
            pass

        try:
            items = self.tbl_ai_managed.selectedItems()
            if items:
                return int(items[0].row())
        except Exception:
            pass

