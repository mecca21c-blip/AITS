            vol_24 = 0.0

        if chg >= 3.0:
            score += 20
            trend_score += 20
            reasons.append("?곸듅瑜??묓샇")
        elif chg >= 1.0:
            score += 10
            trend_score += 10
            reasons.append("?곸듅 ?먮쫫")
        elif chg <= -3.0:
            score -= 25
            trend_score -= 25
            risk_penalty += 25
            reasons.append("湲됰씫 ?곕젮")
        elif chg <= -1.0:
            score -= 10
            trend_score -= 10
            risk_penalty += 10
            reasons.append("?쎌꽭 援ш컙")

        min_vol = int(st.get("min_volume", 0) or 0)
