    def _parse_aits_ai_response(self, raw_text: str) -> dict:
        """
        AI ?묐떟??decision / reason / next_action 援ъ“濡??뚯떛
        ?ㅽ뙣 ??fallback 援ъ“ 諛섑솚
        """
        try:
            s = str(raw_text or "").strip()
            if s.startswith("```"):
                lines = s.split("\n")
                if len(lines) >= 3 and lines[-1].strip() == "```":
                    s = "\n".join(lines[1:-1]).strip()
                elif len(lines) >= 2:
                    s = "\n".join(lines[1:]).strip()
                    if s.endswith("```"):
                        s = s[:-3].strip()
            data = json.loads(s)
            decision = data.get("decision", "?먮떒 遺덇?")
            if decision is None:
                decision = "?먮떒 遺덇?"
            reason = data.get("reason", [])
            if isinstance(reason, str):
                reason = [reason] if str(reason).strip() else []
            elif not isinstance(reason, list):
                reason = []
            next_action = data.get("next_action", [])
            if isinstance(next_action, str):
                next_action = [next_action] if str(next_action).strip() else []
            elif not isinstance(next_action, list):
                next_action = []
            # rotation ??異붽? ?ㅺ? ?덉뼱??json.loads???깃났?섎ŉ, ?꾨옒??decision/reason/next_action留?諛섑솚.
            return {
                "decision": decision,
                "reason": reason,
                "next_action": next_action,
            }
        except Exception:
            return {
                "decision": "?먮떒 遺덇?",
                "reason": [str(raw_text or "")[:200]],
                "next_action": [],
            }

