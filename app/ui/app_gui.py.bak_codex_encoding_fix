            elif trade_value < 500_000_000:
                score -= 0.5
            else:
                score += 0.5

            change_pct = change * 100.0
            if change_pct >= 0:
                if change_pct < 1.0:
                    score += 0.2
                elif change_pct < 3.0:
                    score += 1.0
                elif change_pct < 6.0:
                    score += 1.8
                elif change_pct < 10.0:
