            key = str(getattr(self, "_market_sort_key", "volume") or "volume")
        except Exception:
            key = "volume"
        try:
            order = str(getattr(self, "_market_sort_order", "desc") or "desc").lower()
        except Exception:
            order = "desc"
        reverse = (order != "asc")

        try:
            def _get_val(r):
                try:
                    if key == "volume":
                        return self._get_market_trade_value(r)
                    if key == "change":
                        return self._safe_market_float(
                            r,
                            "change_rate",
                            "signed_change_rate",
                            "change",
                        )
                    if key == "price":
                        return self._safe_market_float(
