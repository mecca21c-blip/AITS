            score = 0.0

            # 嫄곕옒?湲덉? shortlist ?덉쭏???듭떖 吏??留ㅼ닔/留ㅻ룄 ?좏샇 ?꾨떂)
            try:
                score += math.log10(max(trade_value, 1.0))
            except Exception:
                pass

            # 珥덉??좊룞????좊룞??諛⑹뼱
            if trade_value < 10_000_000:
