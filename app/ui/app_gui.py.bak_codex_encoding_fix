def _managed_header_col_wrap(text: str, col_key: str, center: bool) -> QWidget:
    """怨좎젙 ??而щ읆 ?섑띁 + ?ㅻ뜑 QLabel (?뺣젹: center ?먮뒗 醫뚯륫)."""
    w = _MANAGED_COL_WIDTHS[col_key]
