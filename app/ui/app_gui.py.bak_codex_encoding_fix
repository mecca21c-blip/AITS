        if bool(st.get("exclude_overheated", True)) and chg >= 8.0:
            score -= 20
            risk_penalty += 20
            reasons.append("怨쇱뿴 援ш컙")

        if bool(st.get("avoid_sudden_drop", True)) and chg <= -5.0:
            score -= 30
