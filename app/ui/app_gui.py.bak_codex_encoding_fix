                    not is_holding
                    and entry_price is not None
                    and current_price is not None
                    and float(current_price) != 0
                ):
                    entry_is_duplicate = (
                        abs(float(entry_price) - float(current_price)) / abs(float(current_price))
                    ) < 0.002
            except Exception:
                entry_is_duplicate = False

            return {
