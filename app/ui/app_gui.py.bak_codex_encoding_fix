    def _get_aits_decision_variant(self):
        try:
            payload = self._get_aits_final_explanation_payload()
            decision = str(payload.get("decision", "") or "").strip().lower()

            if not decision:
                return "neutral"

            if ("留ㅼ닔" in decision) or ("吏꾩엯" in decision) or ("buy" in decision):
                return "buy"

            if ("愿留? in decision) or ("?湲? in decision) or ("watch" in decision):
                return "watch"

            if ("蹂댁쑀" in decision) or ("?좎?" in decision) or ("hold" in decision):
                return "hold"

            if ("留ㅻ룄" in decision) or ("?듭젅" in decision) or ("?먯젅" in decision) or ("sell" in decision):
                return "risk"

            return "neutral"
        except Exception:
