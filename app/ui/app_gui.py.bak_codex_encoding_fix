    def _compact_ai_status_text(self, text: str) -> str:
        try:
            raw = str(text or "").strip()
            if not raw:
                return "AI ?먮떒: ?뺣낫 ?놁쓬"

            if raw.startswith("AITS ?곹깭:") and "\n" not in raw:
                return raw

            lines = [ln.strip() for ln in raw.splitlines() if str(ln).strip()]
            if not lines:
                return "AI ?먮떒: ?뺣낫 ?놁쓬"

            decision = ""
            reason = ""
            in_reason = False

            for ln in lines:
                low = ln.lower()
                if "[ai ?먮떒]" in low or "[AI ?먮떒]" in ln:
                    if "]" in ln:
                        decision = ln.split("]", 1)[-1].strip()
                    else:
                        decision = ln
                    decision = decision.strip(" :|-")
                    continue
                if "[?먮떒 洹쇨굅]" in ln:
                    in_reason = True
                    continue
                if "[?ㅼ쓬 ?됰룞]" in ln:
                    break
                if in_reason and ln.startswith("-") and not reason:
                    reason = ln.lstrip("-??").strip()
                    if reason:
                        break

            if not decision:
                decision = lines[0]

            out = f"AI ?먮떒: {decision}"
            if reason:
                out += f" | {reason[:80]}"
            return out
        except Exception:
            return "AI ?먮떒: ?뺣낫 ?놁쓬"

