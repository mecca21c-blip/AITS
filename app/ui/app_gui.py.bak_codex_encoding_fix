            if ("吏꾩엯 寃?? in d) or ("留ㅼ닔" in d) or ("buy" in dl):
                return "吏꾩엯 寃??
            if ("蹂댁쑀" in d) or ("?좎?" in d) or ("hold" in dl):
                return "蹂댁쑀 愿李?
            if ("留ㅻ룄" in d) or ("?듭젅" in d) or ("?먯젅" in d) or ("sell" in dl):
