                score += 10
                trend_score += 10
                reasons.append("異붿꽭 ?꾪꽣(媛뺥븿) ?듦낵")
            else:
                score -= 10
                trend_score -= 10
                risk_penalty += 10
                reasons.append("異붿꽭 ?꾪꽣(媛뺥븿) 誘몃떖")
        elif tf == "?쏀븿":
            if chg >= 0.5:
                score += 5
                trend_score += 5
                reasons.append("異붿꽭 ?꾪꽣(?쏀븿) 媛??)

        sel = str(st.get("selection_strength") or "蹂댄넻")
        if sel == "?믪쓬":
            score -= 5
            reasons.append("?좊퀎 媛뺣룄(?믪쓬)")
        elif sel == "??쓬":
            score += 5
            reasons.append("?좊퀎 媛뺣룄(??쓬)")

        rm = str(st.get("risk_mode") or "以묐┰")
        if rm == "怨듦꺽??:
            score += 5
            reasons.append("?댁슜 ?깊뼢: 怨듦꺽")
        elif rm == "蹂댁닔??:
            score -= 5
            reasons.append("?댁슜 ?깊뼢: 蹂댁닔")

        try:
            import time as _time

            let = row.get("last_exit_ts")
            if let is not None:
                let_f = float(let)
                cool = int(st.get("reentry_cooldown_min", 30) or 30)
                if _time.time() - let_f < cool * 60:
                    score -= 20
                    risk_penalty += 20
                    reasons.append("?ъ쭊??荑⑤떎??)
